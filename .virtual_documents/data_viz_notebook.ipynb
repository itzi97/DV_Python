# ---------------------------------------
# Q3a - Weekly overview (3 panel subplot)
# ---------------------------------------

plt.close("all")
sns.set_style("white")

# ============
# 1. DATA PREP
# ============

# Detect activity periods for the top timeline
# A new period starts whenever the gap between activities is more than 60 days
period_df = df.sort_values("Date").copy()
period_df["GapDays"] = period_df["Date"].diff().dt.days
period_df["PeriodID"] = (
    period_df["GapDays"].isna() | (period_df["GapDays"] > 60)
).cumsum()

periods = (
    period_df.groupby("PeriodID")
    .agg(Start=("Date", "min"), End=("Date", "max"))
    .reset_index(drop=True)
)
periods["Duration"] = (periods["End"] - periods["Start"]).dt.days + 1

# Build weekly tables for the two heatmaps
pivot_count = (
    df.groupby(["Year", "Week"])
    .size()
    .unstack(fill_value=0)
    .reindex(columns=range(1, 54), fill_value=0)
)

pivot_who = (
    df.groupby(["Year", "Week"])["WHO Minutes"]
    .sum()
    .unstack(fill_value=0)
    .reindex(columns=range(1, 54), fill_value=0)
)

# Define colormaps
greens = [COLORS["bg"], COLORS["success"], COLORS["deepgreen"]]
count_cmap = LinearSegmentedColormap.from_list("count", greens, N=256)

# WHO heatmap with three different levels
who_cmap = ListedColormap(greens)
who_bounds = [0, 150, 300, pivot_who.to_numpy().max() + 1]
who_norm = BoundaryNorm(who_bounds, who_cmap.N)
who_tick_pos = [(a + b) / 2 for a, b in zip(who_bounds[:-1], who_bounds[1:])]

# ===============
# 2. FIGURE SETUP
# ===============

fig, (ax_top, ax_count, ax_who) = plt.subplots(
    3, 1,
    figsize=(12, 7),
    facecolor=COLORS["bg"],
    gridspec_kw={"height_ratios": [0.8, 2, 2]},
    constrained_layout=True
)

# Helper function to apply consistent formatting to both heatmaps.
def style_panel(ax, title):
    apply_theme(ax)
    ax.set_title(title, fontsize=16, fontweight="bold", pad=12)
    ax.set_xlabel("Week")
    ax.set_ylabel("Year")
    ax.tick_params(axis="x", labelsize=9)
    ax.tick_params(axis="y", labelsize=10, labelrotation=0)

# ================================
# 3. TOP PANEL - ACTIVITY TIMELINE
# ================================

# Draw one horizontal bar for each detected activity period
for _, row in periods.iterrows():
    ax_top.barh(
        0,
        row["Duration"],
        left=row["Start"],
        height=0.35,
        color=COLORS["success"],
        edgecolor="none",
        alpha=0.95
    )

# Format the timeline axis
ax_top.set_xlim(pd.Timestamp("2021-01-01"), pd.Timestamp("2026-03-31"))
ax_top.set_yticks([])
ax_top.set_ylim(-0.8, 0.8)
ax_top.set_title(
    "Activity Periods",
    fontsize=16,
    fontweight="bold",
    pad=10
)

# Show years on the x-axis and minor ticks every 3 months
ax_top.xaxis.set_major_locator(mdates.YearLocator())
ax_top.xaxis.set_major_formatter(mdates.DateFormatter("%Y"))
ax_top.xaxis.set_minor_locator(mdates.MonthLocator(interval=3))

# Add faint vertical year separators.
for year in range(2021, 2027):
    ax_top.axvline(
        pd.Timestamp(f"{year}-01-01"),
        color=COLORS["grid"],
        linewidth=0.8,
        zorder=0
    )

# Clean up the panel styling
for spine in ax_top.spines.values():
    spine.set_visible(False)

apply_theme(ax_top)
ax_top.tick_params(axis="x", length=0, pad=6)

# =======================================
# 4. MIDDLE PANEL - WEEKLY ACTIVITY COUNT
# =======================================

hm_count = sns.heatmap(
    pivot_count,
    cmap=count_cmap,
    linewidths=0.6,
    linecolor="white",
    xticklabels=2,
    cbar=True,
    cbar_kws={"label": "# Activities"},
    ax=ax_count
)

style_panel(ax_count, "Weekly Activity Frequency")

# Add values inside cells for weeks with at least one activity
for i in range(pivot_count.shape[0]):
    for j in range(pivot_count.shape[1]):
        val = int(pivot_count.iloc[i, j])
        if val > 0:
            ax_count.text(
                j + 0.5,
                i + 0.5,
                str(val),
                ha="center",
                va="center",
                fontsize=8,
                color="white" if val >= 8 else "black"
            )

# Simplify the count colorbar.
cbar_count = hm_count.collections[0].colorbar
cbar_count.set_ticks([])
cbar_count.outline.set_visible(False)
cbar_count.ax.yaxis.label.set_color(COLORS["text"])

# ==========================================
# 5. BOTTOM PANEL - WEEKLY WHO BENEFIT LEVEL
# ==========================================

hm_who = sns.heatmap(
    pivot_who,
    cmap=who_cmap,
    norm=who_norm,
    linewidths=0.6,
    linecolor="white",
    xticklabels=2,
    cbar=True,
    cbar_kws={"label": "Health Benefit"},
    ax=ax_who
)

style_panel(ax_who, "Weekly Health Benefit Level")

# Replace numeric colorbar ticks with category labels
cbar_who = hm_who.collections[0].colorbar
cbar_who.set_ticks(who_tick_pos)
cbar_who.set_ticklabels(["Below", "Meets", "Extra"])
cbar_who.ax.tick_params(length=0, colors=COLORS["text"], labelsize=8, pad=2)
cbar_who.outline.set_visible(False)
cbar_who.ax.yaxis.label.set_color(COLORS["text"])

# ==============
# 6. SAVE + SHOW
# ==============

plt.savefig(
    "figures/q3_weekly_overview.png",
    dpi=300,
    bbox_inches="tight",
    facecolor=COLORS["bg"]
)
plt.show()





# ---------------------------
# Q3b - Weekly lollipop chart
# ---------------------------

def plot_lollipop(year):
    plt.close("all")
    
    # Get WHO minutes per week for this year (missing weeks -> 0)
    weekly = (df[df["Year"] == year]
        .groupby("Week")["WHO Minutes"].sum()
        .reindex(range(1, 54), fill_value=0)
        .reset_index()
    )
    
    # Keep only weeks with recorded activity
    active_weeks = weekly[weekly["WHO Minutes"] > 0]

    # Create figure and grab axis
    plt.figure(figsize=(12,6), facecolor=COLORS["bg"])
    ax = plt.gca()
    
    # Draw lollipops - thin line + dot, color by WHO target
    for _, row in active_weeks.iterrows():
        mins = row["WHO Minutes"]
        if mins >= 300:
            color = COLORS["deepgreen"]
        elif mins >= 150:
            color = COLORS["success"]
        else:
            color = COLORS["below"]
        
        ax.vlines(row["Week"], 0, mins, color=color, linewidth=4, alpha=0.75)
        ax.scatter(row["Week"], mins, s=120, color=color, alpha=0.9, zorder=3)
    
    # Target lines
    ax.axhline(
        150, 
        color=COLORS["accent"], 
        lw=2.5, 
        ls="--", 
        label="150 min target"
    )
    ax.axhline(
        300, 
        color=COLORS["deepgreen"], 
        lw=2.5, 
        ls=":", 
        label="300 min target"
    )

    # Set axis limits and labels
    ax.set_xlim(0.5, 53.5)      # Center around 1 to 53 week count
    ax.set_xticks(range(1, 54)) # 53 ISO Weeks in Year
    ax.set_ylim(0, 800)         # Hardcoded upper limit
    ax.set_yticks([0, 150, 300, 450, 600, 750])
    ax.set_xlabel("Week")
    ax.set_ylabel("Activity Minutes")
    ax.set_title(
        f"Weekly Activity Minutes ({year})",
        fontsize=16,
        fontweight="bold",
        pad=10
    )

    # Apply theme, remove frame from legend
    apply_theme(ax)
    ax.legend(frameon=False)
    plt.tight_layout()

    # Save and show chart
    plt.savefig(f'figures/q3_lollipop_{year}.png', dpi=300, bbox_inches='tight', 
                facecolor=COLORS["bg"])
    plt.show()

# Dropdown to pick year
years = sorted(df["Year"].dropna().unique())
year_dropdown = widgets.Dropdown(
    options=years, 
    value=years[-1], 
    description="Year:"
)
display(
    year_dropdown, 
    widgets.interactive_output(plot_lollipop, {"year": year_dropdown})
)





# ---------------------------------------
# Q3c - 2026 trend chart
# ---------------------------------------

# Data prep
weekly_trend = (
    df[df["Year"] == 2026]
    .groupby("Week")["WHO Minutes"]
    .sum()
    .reset_index()
    .sort_values("Week")
)

# Take each week number in 2026, turn it into ISO week date string
# Convert to real start date for that week
weekly_trend["WeekStart"] = pd.to_datetime(
    "2026-W" + weekly_trend["Week"].astype(str).str.zfill(2) + "-1",
    format="%G-W%V-%u"
)

# Color code points depending on met threshold
weekly_trend["ColorBand"] = pd.cut(
    weekly_trend["WHO Minutes"],
    bins=[0, 150, 300, weekly_trend["WHO Minutes"].max() + 1],
    labels=False
)

# Plot set up
plt.figure(figsize=(12, 6), facecolor=COLORS["bg"])
ax = plt.gca()

# Regression line
sns.regplot(
    data=weekly_trend,
    x="Week",
    y="WHO Minutes",
    scatter=False,
    line_kws={"color": COLORS["accent"], "lw": 3},
    ax=ax
)

ax.collections[0].set_alpha(0.08)

# Colored scatter plot (different colors for different thresholds)
color_map = {
    0: COLORS["below"],
    1: COLORS["success"],
    2: COLORS["deepgreen"]
}

for band, color in color_map.items():
    subset = weekly_trend[weekly_trend["ColorBand"] == band]
    ax.scatter(
        subset["Week"],
        subset["WHO Minutes"],
        s=120,
        alpha=0.85,
        color=color,
        label=None,
        zorder=3
    )

# Target lines
ax.axhline(150, color=COLORS["accent"], lw=2, ls="--", 
           label="150 min target")
ax.axhline(300, color=COLORS["deepgreen"], lw=2, ls=":", 
           label="300 min target")

# Ticks, label and title formatting
ax.set_xticks(weekly_trend["Week"])
ax.set_xticklabels(
    weekly_trend["WeekStart"].dt.strftime("%b %d"),
    rotation=0, ha="center"
)

ax.set_xlabel("Week Start Date (2026)", fontsize=12, labelpad=10)
ax.set_ylabel("Weekly Activity Minutes", fontsize=12, labelpad=8)
ax.set_title(
    "2026 Weekly Activity Trend",
    fontsize=16, fontweight="bold", pad=16
)

# Themeing
apply_theme(ax)
ax.grid(False)
ax.legend(frameon=False)
plt.tight_layout()

# Save and show
plt.savefig(
    "figures/q3_trend.png",
    dpi=300, bbox_inches="tight", facecolor=COLORS["bg"]
)
plt.show()



