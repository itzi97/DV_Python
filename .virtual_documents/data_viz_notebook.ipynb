# -----------------------------
# Q3a - Weekly overview heatmap
# -----------------------------

# Weekly tables
pivot_count = (
    df.groupby(["Year", "Week"])
      .size()
      .unstack(fill_value=0)
      .reindex(columns=range(1, 54), fill_value=0)
)

pivot_who = (
    df.groupby(["Year", "Week"])["WHO Minutes"]
      .sum()
      .unstack(fill_value=0)
      .reindex(columns=range(1, 54), fill_value=0)
)

# Activity periods
period_df = df.sort_values("Date").copy()
period_df["GapDays"] = period_df["Date"].diff().dt.days
period_df["PeriodID"] = (
    period_df["GapDays"].isna() | (period_df["GapDays"] > 60)
).cumsum()

periods = (
    period_df.groupby("PeriodID")
    .agg(Start=("Date", "min"), End=("Date", "max"))
    .reset_index(drop=True)
)
periods["Duration"] = (periods["End"] - periods["Start"]).dt.days + 1

# Colormaps
greens = [COLORS["bg"], COLORS["success"], COLORS["deep_green"]]
count_cmap = LinearSegmentedColormap.from_list("count", greens)

who_cmap = ListedColormap(greens)
who_bounds = [0, 150, 300, pivot_who.to_numpy().max() + 1]
who_norm = BoundaryNorm(who_bounds, who_cmap.N)
who_ticks = [(a + b) / 2 for a, b in zip(who_bounds[:-1], who_bounds[1:])]

# Figure
plt.close("all")
sns.set_style("white")

fig, (ax0, ax1, ax2) = plt.subplots(
    3, 1,
    figsize=(12, 7),
    facecolor=COLORS["bg"],
    gridspec_kw={"height_ratios": [1, 2, 2]},
    constrained_layout=True
)

def format_panel(ax, title):
    apply_theme(ax)
    ax.set_title(title, fontsize=16, fontweight="bold", pad=12)
    ax.set_xlabel("Week")
    ax.set_ylabel("Year")
    ax.tick_params(axis="x", labelsize=9)
    ax.tick_params(axis="y", labelsize=10, labelrotation=0)

# Top timeline
for _, row in periods.iterrows():
    ax0.barh(
        0, row["Duration"], left=row["Start"], height=0.35,
        color=COLORS["success"], edgecolor="none", alpha=0.95
    )

ax0.set_xlim(pd.Timestamp("2021-01-01"), pd.Timestamp("2026-03-31"))
ax0.set_yticks([])
ax0.set_ylim(-0.8, 0.8)
ax0.set_title("Activity Periods", fontsize=16, fontweight="bold",
              color=COLORS["accent"], pad=10)

ax0.xaxis.set_major_locator(mdates.YearLocator())
ax0.xaxis.set_major_formatter(mdates.DateFormatter("%Y"))
ax0.xaxis.set_minor_locator(mdates.MonthLocator(interval=3))

for year in range(2021, 2027):
    ax0.axvline(pd.Timestamp(f"{year}-01-01"),
                color=COLORS["grid"], linewidth=0.8, zorder=0)

for spine in ax0.spines.values():
    spine.set_visible(False)

apply_theme(ax0)
ax0.tick_params(axis="x", length=0, pad=6)

# Middle heatmap: activity count
hm1 = sns.heatmap(
    pivot_count,
    cmap=count_cmap,
    linewidths=0.6,
    linecolor="white",
    xticklabels=2,
    cbar=True,
    cbar_kws={"label": "# of Activities"},
    ax=ax1
)
format_panel(ax1, "Weekly Activity Frequency")

for i in range(pivot_count.shape[0]):
    for j in range(pivot_count.shape[1]):
        value = int(pivot_count.iloc[i, j])
        if value > 0:
            ax1.text(
                j + 0.5, i + 0.5, str(value),
                ha="center", va="center",
                fontsize=8,
                color="white" if value >= 8 else "black"
            )

cbar1 = hm1.collections[0].colorbar
cbar1.set_ticks([])
cbar1.outline.set_visible(False)
cbar1.ax.yaxis.label.set_color(COLORS["text"])

# Bottom heatmap: WHO levels
hm2 = sns.heatmap(
    pivot_who,
    cmap=who_cmap,
    norm=who_norm,
    linewidths=0.6,
    linecolor="white",
    xticklabels=2,
    cbar=True,
    cbar_kws={"label": "Health Benefit"},
    ax=ax2
)
format_panel(ax2, "Weekly Activity Health Benefit Level")

cbar2 = hm2.collections[0].colorbar
cbar2.set_ticks(who_ticks)
cbar2.set_ticklabels(["Below", "Meets", "Extra"])
cbar2.ax.tick_params(length=0, colors=COLORS["text"], labelsize=8, pad=2)
cbar2.outline.set_visible(False)
cbar2.ax.yaxis.label.set_color(COLORS["text"])

plt.savefig(
    "figures/q2_heatmap_overview.png",
    dpi=300,
    bbox_inches="tight",
    facecolor=COLORS["bg"]
)
plt.show()





# -----------------------------
# Q3b - Weekly lollipop chart
# -----------------------------

def plot_lollipop(year):
    plt.close("all")

    # Aggregate WHO-equivalent minutes per week, filling missing weeks with 0
    weekly = (df[df["Year"] == year]
              .groupby("Week")["WHO Minutes"].sum()
              .reindex(range(1, 54), fill_value=0)
              .reset_index())

    # Only plot weeks with recorded activity
    active = weekly[weekly["WHO Minutes"] > 0]

    fig, ax = plt.subplots(figsize=(12, 6), facecolor=COLORS["bg"])
    ax.set_facecolor(COLORS["bg"])

    # Draw each lollipop: stem + dot, colored by WHO tier
    for _, row in active.iterrows():
        color = (COLORS["deep_green"] if row["WHO Minutes"] >= 300
                 else COLORS["success"] if row["WHO Minutes"] >= 150
                 else COLORS["below"])
        ax.vlines(row["Week"], 0, row["WHO Minutes"],
                  color=color, linewidth=4, alpha=0.75)
        ax.scatter(row["Week"], row["WHO Minutes"],
                   s=120, color=color, alpha=0.9, zorder=3)

    # WHO reference lines
    ax.axhline(150, color=COLORS["accent"], lw=2.5, ls="--",
               label="WHO Target (150 min/week)")
    ax.axhline(300, color=COLORS["deep_green"], lw=2.5, ls=":",
               label="Enhanced Target (300 min/week)")

    # Y-axis ticks aligned to WHO thresholds for easy reading
    ax.set_xlim(0.5, 53.5)
    ax.set_xticks(range(1, 54))
    ax.set_ylim(0, 800)
    ax.set_yticks([0, 150, 300, 450, 600, 750])
    ax.set_xlabel(f"ISO Week ({year})", fontsize=12, labelpad=10)
    ax.set_ylabel("Total Weekly WHO-Equivalent Minutes",
                  fontsize=12, labelpad=8)
    ax.set_title(f"Weekly WHO-Equivalent Intensity vs Target ({year})",
                 fontsize=16, fontweight="bold", pad=20)
    apply_theme(ax)
    ax.legend(loc="upper right", frameon=False)
    plt.tight_layout()
    plt.savefig(f'figures/q2_lollipop_{year}.png', dpi=300,
                bbox_inches='tight', facecolor=COLORS["bg"])
    plt.show()

# Interactive dropdown to select year without rerunning the cell
year_selector = widgets.Dropdown(
    options=sorted(df["Year"].dropna().unique()),
    value=sorted(df["Year"].dropna().unique())[-1],
    description="Year"
)
display(year_selector, widgets.interactive_output(
    plot_lollipop, {"year": year_selector}
))





# -----------------------------
# Q3c - 2026 trend chart
# -----------------------------

# Aggregate WHO equivalent minutes per week for 2026
weekly_trend = (df[df['Year'] == 2026]
                .groupby('Week')['WHO Minutes'].sum().reset_index())

# Sequential week number for regression x-axis
weekly_trend['Week_Seq'] = range(1, len(weekly_trend) + 1)
# ISO weeks start Monday, anchored to first Monday of 2026
weekly_trend['Week_Start'] = pd.date_range(
    start='2026-01-05', periods=len(weekly_trend), freq='W-MON')

fig, ax = plt.subplots(figsize=(12, 6), facecolor=COLORS["bg"])
ax.set_facecolor(COLORS["bg"])

# Regression line only scatter drawn manually below for color control
sns.regplot(data=weekly_trend, x='Week_Seq', y='WHO Minutes',
            scatter=False, line_kws={'color': COLORS["accent"], 'lw': 3},
            ax=ax)
# Reduce confidence interval opacity to avoid cluttering a small sample
ax.collections[0].set_alpha(0.05)

# Manual scatter colored by WHO tier
for mask, color in [
    (weekly_trend['WHO Minutes'] < 150, COLORS["below"]),
    ((weekly_trend['WHO Minutes'] >= 150) & (weekly_trend['WHO Minutes'] < 300),
     COLORS["success"]),
    (weekly_trend['WHO Minutes'] >= 300, COLORS["deep_green"]),
]:
    ax.scatter(weekly_trend.loc[mask, 'Week_Seq'],
               weekly_trend.loc[mask, 'WHO Minutes'],
               s=120, alpha=0.8, color=color, zorder=3)

# WHO reference lines
ax.axhline(150, color=COLORS["accent"], lw=2, ls="--",
           label="WHO Target: 150 min/week")
ax.axhline(300, color=COLORS["deep_green"], lw=2, ls=":",
           label="Enhanced Target: 300 min/week")

# Use actual dates on x axis instead of week numbers for readability
ax.set_xticks(weekly_trend['Week_Seq'])
ax.set_xticklabels(weekly_trend['Week_Start'].dt.strftime('%b %d'),
                   rotation=0, ha='center')
ax.set_xlabel('Week Start Date (2026)', fontsize=12, labelpad=10)
ax.set_ylabel('Active Minutes', fontsize=12, labelpad=6)
ax.set_title('2026 Training: Weekly Activity vs WHO Targets',
             fontsize=15, fontweight='bold')
apply_theme(ax)
ax.legend(frameon=False)
plt.tight_layout()
plt.savefig('figures/q2_trend_2026.png', dpi=300,
            bbox_inches='tight', facecolor=COLORS["bg"])
plt.show()



