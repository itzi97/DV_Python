df = pd.read_csv("data/activities.csv")
print(f"Raw shape: {df.shape}")
print("\nFirst rows:")
df.head()





df.info()











unused_cols = [
    'Favorite', 'Total Reps', 'Total Sets', 'Decompression', 'Best Lap Time',
    'Avg Cadence', 'Total Strokes', 'Avg. Swolf', 'Elapsed Time', 
    'Number of Laps', 'Avg Stroke Rate', 'Avg Stride Length', 'Max Cadence',
    'Training Stress Score®', 'Moving Time', 'Activity_Group', 'Avg Pace',
    'Best Pace', 'Min Elevation', 'Max Elevation', 'Total Ascent', 'Total Descent'
]
df = df.drop(columns=[col for col in unused_cols if col in df.columns], errors='ignore')
print(f"After drops: {df.shape}")





df = df.replace('--', np.nan)





for col in ["Calories", "Steps", "Distance", "Avg HR", "Max HR", "Aerobic TE"]:
    if col in df.columns:
        df[col] = pd.to_numeric(df[col].astype(str).str.replace(",", ""), errors='coerce')





df["Date"] = pd.to_datetime(df["Date"], errors='coerce')
if 'Time' in df.columns:
    df['Time'] = pd.to_timedelta(df['Time'], errors='coerce')





df['Year'] = df['Date'].dt.year
df['Week'] = df['Date'].dt.isocalendar().week





df['Activity Type'] = df['Activity Type'].astype(str).replace({
    'Treadmill Running': 'Running',
    'Trail Running': 'Running'
})
df['Activity Type'] = pd.Categorical(df['Activity Type'])
print("Activity types:", df['Activity Type'].cat.categories.tolist())





df['Intensity'] = pd.cut(df.get('Avg HR', 0), bins=[-np.inf, 140, np.inf], 
                        labels=['Moderate', 'Vigorous'])

# Compute minutes first to then compute WHO equivalent minutes
mins = df['Time'].dt.total_seconds().fillna(0) / 60
df['WHO Minutes'] = np.where(df['Intensity'] == 'Vigorous',  mins * 2, mins)





df['Location'] = df['Title'].str.extract(r'^(.*?)(?:\s+(Walking|Running|Swimming|Cycling|Treadmill|\bPool\b)|-)')[0].str.strip()
df['Location'] = df['Location'].where(~df['Location'].isin(['Treadmill', 'Pool', '', pd.NA]))
print("Locations:", df['Location'].value_counts().head())





# Set Plotly renderer
pio.renderers.default = "notebook_connected"

# Set matplotlib default global settings
plt.style.use("default")
plt.rcParams.update({
    "font.size": 11,
    "axes.linewidth": 1.2,
})

COLORS = {
    "accent": "#0d9488",       # teal-600: used for titles, axis labels, emphasis
    "text": "#475569",         # gray-600: used for tick labels and general text
    "deepgreen": "#047857",    # emerald-700: higher threshold met
    "success": "#10b981",      # emerald-500: used for normal or positive values
    "lightgreen": "#a7f3d0",   # emerald-300: lower values
    "below": "#94a3b8",        # slate-400: used for values below target
    "grid": "#e2e8f0",         # slate-200: used for subtle borders and grid lines
    "bg": "#f8fafc",           # slate-50: light background
}

def apply_theme(ax, despine_left=False):
    
    # Set the background color of the plotting area.
    ax.set_facecolor(COLORS["bg"])
    
    # Set the color of tick labels and tick marks.
    ax.tick_params(colors=COLORS["text"])

    # Remove the top and right spines to create a cleaner, less boxed-in look.
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)

    # Style the remaining spines (left and bottom) with a light grid color
    # so they stay visible but do not dominate the chart.
    ax.spines["left"].set_color(COLORS["grid"])
    ax.spines["bottom"].set_color(COLORS["grid"])

    # Color the axis labels and title using the accent color
    # so headings and labels stand out consistently across charts.
    ax.xaxis.label.set_color(COLORS["accent"])
    ax.yaxis.label.set_color(COLORS["accent"])
    ax.title.set_color(COLORS["accent"])
    
    # Add a bit of fixed padding so tick labels do not sit too close
    # to the axes, improving readability (and consistency).
    ax.tick_params(axis="x", pad=8)
    ax.tick_params(axis="y", pad=5)

    # Remove grid and legend border from ax
    ax.grid(False)





